# Secrets & local config — never commit
.env
.env.*

# OS / editor cruft
.DS_Store

# Local Claude Code state (keep skills/ + workflows/, ignore local settings)
.claude/settings.local.json

# Build artifacts — Rust workspace + frontend
/target
**/node_modules
src-ui/dist

# Tauri build-generated schemas/capabilities (regenerated each build by tauri-build)
crates/*/gen/schemas/

# agent scratch / regenerable
.playwright-mcp/
test-assets/
*.log
*.png
