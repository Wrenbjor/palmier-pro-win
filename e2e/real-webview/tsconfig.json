{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node", "@wdio/globals/types", "@wdio/mocha-framework", "expect-webdriverio"]
  },
  "ts-node": {
    "transpileOnly": true,
    "files": true
  }
}
